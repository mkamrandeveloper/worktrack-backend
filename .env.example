GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=30d
PORT=3001
NODE_ENV=production

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
# Get this connection string from your provider's dashboard:
#   Render:   Dashboard → your Postgres instance → "External Connection String"
#   Railway:  Project → Postgres plugin → "Connect" tab → DATABASE_URL
#   Supabase: Project Settings → Database → "Connection string" (URI, not pooler)
DATABASE_URL=postgres://user:password@host:5432/dbname
# Set to "true"/"false" to force SSL on/off. Auto-detected (on for non-localhost
# hosts) when unset — most managed providers require SSL.
# DB_SSL=true

# ── App / Email ───────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3001
# SMTP for invite & credential emails. Fill these in to enable real delivery.
# (Gmail: use an App Password, not your account password.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=WorkTrack <no-reply@worktrack.io>
